<!DOCTYPE html>
<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta charset="utf-8">
<title>Automint Installer</title>
<HTA:APPLICATION
  ID="AutomintInstaller"
  BORDER="none"
  BORDERSTYLE="none"
  CAPTION="no"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  SYSMENU="no"
  SCROLL="no"
  CONTEXTMENU="no"
  SELECTION="no"
/>
<style>
/* ============================================================
   Installer — minimal enterprise surface.
   HTA/MSHTML — no CSS custom properties, no web fonts.
   Palette mirrors shared/theme.css:
     primary     #00FF41
     primary-h   #00CC33
     bg-deep     #030303
     text        #FFFFFF
     text-2      #A0A0A0
     text-3      #555555
   ============================================================ */

* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
  width: 100%;
  height: 100%;
  overflow: hidden;
  font-family: "Segoe UI Variable Display", "Segoe UI", Tahoma, sans-serif;
  background: #030303;
  color: #FFFFFF;
  -ms-user-select: none;
  user-select: none;
}

body {
  opacity: 1;
  transition: opacity 0.5s ease;
}

/* ── Close button ──────────────────────────────────────────── */

.close-btn {
  position: fixed;
  top: 10px;
  right: 12px;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Segoe UI", Arial, sans-serif;
  font-size: 14px;
  font-weight: 400;
  color: #A0A0A0;
  cursor: pointer;
  z-index: 100;
  border: none;
  background: transparent;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
}
.close-btn:hover {
  color: #FFFFFF;
  background: rgba(255,255,255,0.06);
}

/* ── Drag region ───────────────────────────────────────────── */

.drag-region {
  position: fixed;
  top: 0;
  left: 0;
  right: 40px;
  height: 40px;
  z-index: 50;
  cursor: move;
}

/* ── Content ───────────────────────────────────────────────── */

.content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  padding: 0 56px;
  text-align: center;
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 44px;
}

.brand-logo {
  width: 64px;
  height: 64px;
  border-radius: 14px;
  margin-bottom: 20px;
  box-shadow: 0 0 0 1px rgba(0,255,65,0.12),
              0 10px 32px rgba(0,255,65,0.16);
  opacity: 0;
  transform: scale(0.92);
  animation:
    logoIn 520ms cubic-bezier(0.16, 1, 0.3, 1) 60ms forwards,
    logoBreath 3.2s ease-in-out 700ms infinite,
    logoFloat 5s ease-in-out 1000ms infinite;
}

@keyframes logoIn {
  to { opacity: 1; transform: scale(1); }
}

@keyframes logoBreath {
  0%, 100% {
    box-shadow: 0 0 0 1px rgba(0,255,65,0.12),
                0 10px 32px rgba(0,255,65,0.16);
  }
  50% {
    box-shadow: 0 0 0 1px rgba(0,255,65,0.24),
                0 10px 40px rgba(0,255,65,0.26);
  }
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-3px); }
}

.brand-name {
  font-family: "Segoe UI Variable Display", "Segoe UI", Arial, sans-serif;
  font-size: 22px;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: -0.01em;
  opacity: 0;
  transform: translateY(4px);
  animation: fadeUp 420ms ease 180ms forwards;
}

.brand-version {
  margin-top: 6px;
  font-size: 12px;
  font-weight: 400;
  color: #555555;
  letter-spacing: 0.02em;
  opacity: 0;
  animation: fadeIn 420ms ease 260ms forwards;
}

@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  to { opacity: 1; }
}

/* ── Status text ───────────────────────────────────────────── */

.status {
  font-size: 13px;
  font-weight: 400;
  color: #A0A0A0;
  margin-bottom: 18px;
  min-height: 18px;
  opacity: 0;
  animation: fadeIn 420ms ease 340ms forwards;
  transition: color 200ms ease;
}

.status.complete {
  color: #FFFFFF;
}

/* ── Progress bar ──────────────────────────────────────────── */

.progress-track {
  width: 280px;
  height: 2px;
  background: rgba(255,255,255,0.08);
  border-radius: 1px;
  overflow: hidden;
  margin: 0 auto;
  opacity: 0;
  animation: fadeIn 420ms ease 420ms forwards;
}

.progress-fill {
  position: relative;
  height: 100%;
  width: 0%;
  background: #00FF41;
  border-radius: 1px;
  transition: width 0.3s ease;
  box-shadow: 0 0 8px rgba(0,255,65,0.45);
  overflow: hidden;
}

.progress-fill:before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(255,255,255,0) 0%,
    rgba(255,255,255,0.55) 50%,
    rgba(255,255,255,0) 100%
  );
  animation: progressShimmer 1.8s linear infinite;
}

@keyframes progressShimmer {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}

/* ── Launch button ─────────────────────────────────────────── */

.launch-area {
  display: none;
  margin-top: 4px;
  opacity: 0;
  transform: translateY(4px);
  animation: fadeUp 320ms ease forwards;
}

.launch-btn {
  padding: 10px 36px;
  background: #00FF41;
  color: #030303;
  font-family: "Segoe UI Variable Display", "Segoe UI", Arial, sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,255,65,0.18);
  transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
  animation: btnAmbient 2.8s ease-in-out infinite;
}
.launch-btn:hover {
  background: #00CC33;
  box-shadow: 0 6px 20px rgba(0,255,65,0.28);
  animation: none;
}
.launch-btn:active {
  transform: translateY(1px);
  box-shadow: 0 3px 12px rgba(0,255,65,0.2);
}

@keyframes btnAmbient {
  0%, 100% { box-shadow: 0 4px 16px rgba(0,255,65,0.18); }
  50%      { box-shadow: 0 6px 24px rgba(0,255,65,0.34); }
}
</style>
</head>
<body>

<!-- Drag region -->
<div class="drag-region" id="dragRegion"></div>

<!-- Close button -->
<button class="close-btn" id="closeBtn" title="Close">&#x2715;</button>

<!-- Content -->
<div class="content">
  <div class="brand">
    <img class="brand-logo" id="brandLogo" src="data:image/png;base64," alt="" />
    <div class="brand-name">Automint</div>
    <div class="brand-version" id="version">Version 1.0.0</div>
  </div>

  <div class="status" id="status">Installing&#8230;</div>

  <div class="progress-track" id="progressArea">
    <div class="progress-fill" id="progressFill"></div>
  </div>

  <div class="launch-area" id="launchArea">
    <button class="launch-btn" id="launchBtn">Launch Automint</button>
  </div>
</div>

<script>
// ── State ───────────────────────────────────────────────

var installDir = "";
var isComplete = false;
var progressTimer = null;
var crawlTimer = null;
var currentPct = 0;

// ── Window setup ────────────────────────────────────────

function initWindow() {
  // NSIS strips chrome and repositions us via SetWindowPos.
  window.moveTo(-2000, -2000);
}

// ── Drag support ────────────────────────────────────────

var isDragging = false;
var dragOffsetX = 0;
var dragOffsetY = 0;

function initDrag() {
  var dragRegion = document.getElementById("dragRegion");
  dragRegion.onmousedown = function(e) {
    isDragging = true;
    dragOffsetX = e.screenX - window.screenLeft;
    dragOffsetY = e.screenY - window.screenTop;
  };
  document.onmousemove = function(e) {
    if (isDragging) {
      window.moveTo(e.screenX - dragOffsetX, e.screenY - dragOffsetY);
    }
  };
  document.onmouseup = function() {
    isDragging = false;
  };
}

// ── Progress ────────────────────────────────────────────

function setProgress(pct) {
  currentPct = pct;
  document.getElementById("progressFill").style.width = pct + "%";
}

function startCrawl() {
  // Fake-crawl to 90% while NSIS does the real work.
  // Real completion snaps us to 100%.
  crawlTimer = setInterval(function() {
    if (isComplete) return;
    if (currentPct < 90) {
      setProgress(currentPct + 1);
    }
  }, 180);
}

// ── Progress file polling ───────────────────────────────

function readProgressFile() {
  try {
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    var tempDir = fso.GetSpecialFolder(2) + "";
    var path = tempDir + "\\automint-progress.txt";
    if (!fso.FileExists(path)) return null;
    var file = fso.OpenTextFile(path, 1, false);
    var content = file.ReadAll();
    file.Close();
    return content;
  } catch(e) {
    return null;
  }
}

function checkProgress() {
  var content = readProgressFile();
  if (!content) return;

  var lines = content.split("\n");
  var status = lines[0].replace(/\r/g, "");

  if (status === "complete" && !isComplete) {
    isComplete = true;
    if (lines.length > 1) {
      installDir = lines[1].replace(/\r/g, "").replace(/\n/g, "");
    }
    showCompletion();
  }
}

// ── Completion ──────────────────────────────────────────

function showCompletion() {
  if (crawlTimer) {
    clearInterval(crawlTimer);
    crawlTimer = null;
  }

  setProgress(100);
  var statusEl = document.getElementById("status");
  statusEl.innerText = "Automint is ready to launch.";
  statusEl.className = "status complete";

  setTimeout(function() {
    document.getElementById("progressArea").style.display = "none";
    document.getElementById("launchArea").style.display = "block";
  }, 420);
}

// ── Launch ──────────────────────────────────────────────

function launchApp() {
  if (!installDir) return;
  try {
    var shell = new ActiveXObject("WScript.Shell");
    shell.Run('"' + installDir + '\\Automint.exe"', 1, false);
  } catch(e) {}

  document.body.style.opacity = "0";
  setTimeout(function() {
    cleanupTempFiles();
    window.close();
  }, 500);
}

// ── Close / cancel ──────────────────────────────────────

function cleanupTempFiles() {
  try {
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    var tempDir = fso.GetSpecialFolder(2) + "";
    fso.DeleteFile(tempDir + "\\automint-progress.txt");
    fso.DeleteFile(tempDir + "\\automint-installer.lnk");
    fso.DeleteFile(tempDir + "\\icon.ico");
    fso.DeleteFile(tempDir + "\\installer.hta");
  } catch(e) {}
}

function closeInstaller() {
  cleanupTempFiles();
  window.close();
}

// ── Init ────────────────────────────────────────────────

function init() {
  initWindow();
  initDrag();

  document.getElementById("closeBtn").onclick = closeInstaller;
  document.getElementById("launchBtn").onclick = launchApp;

  setProgress(8);
  startCrawl();
  progressTimer = setInterval(checkProgress, 300);
}

window.onload = init;
</script>

</body>
</html>
